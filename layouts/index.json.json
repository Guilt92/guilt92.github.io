{
  "pages": [
  {{- $first := true -}}
  {{- range .Site.RegularPages -}}
    {{- if not $first }},{{ end -}}
    {{- $first = false -}}
    {
      "title": {{ .Title | jsonify }},
      "permalink": {{ .Permalink | jsonify }},
      "date": {{ .Date.Format "2006-01-02" | jsonify }},
      "categories": {{ .Params.categories | jsonify }},
      "tags": {{ .Params.tags | jsonify }},
      "plain": {{ .Plain | jsonify }},
      "excerpt": {{ .Params.excerpt | jsonify }}
    }
  {{- end -}}
  ]
}
